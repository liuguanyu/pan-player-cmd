package config

import (
	"fmt"
)

// 凭证配置结构
type BaiduCredentials struct {
	AppID        string
	ClientID     string
	ClientSecret string
	SignKey      string
	RedirectURI  string
	Scope        string
	DeviceName   string
}

// 内置的百度网盘 API 凭证示例
// 使用说明：
// 1. 复制此文件为 credentials.go
// 2. 将下面的占位符替换为您自己的真实凭证
// 3. credentials.go 不会被提交到 git（已在 .gitignore 中配置）
//
// 获取凭证：
// - 访问百度网盘开放平台：https://pan.baidu.com/union/
// - 创建应用获取 AppID、ClientID、ClientSecret 和 SignKey
var BaiduCredentialsConfig = BaiduCredentials{
	AppID:        "YOUR_APP_ID",           // 替换为您的 AppID
	ClientID:     "YOUR_CLIENT_ID",        // 替换为您的 Client ID (App Key)
	ClientSecret: "YOUR_CLIENT_SECRET",    // 替换为您的 Client Secret (Secret Key)
	SignKey:      "YOUR_SIGN_KEY",         // 替换为您的签名密钥
	RedirectURI:  "oob",
	Scope:        "basic,netdisk",
	DeviceName:   "度盘读天下",
}

// LoadBaiduCredentials 加载百度网盘凭证（从内置配置）
func LoadBaiduCredentials() (*BaiduCredentials, error) {
	// 直接返回内置凭证
	return &BaiduCredentialsConfig, nil
}

// Validate 验证凭证是否有效
func (c *BaiduCredentials) Validate() error {
	if c.ClientID == "" {
		return fmt.Errorf("client_id is empty")
	}
	if c.ClientSecret == "" {
		return fmt.Errorf("client_secret is empty")
	}
	return nil
}
